# Google Maps API key — required for all address lookups
GOOGLE_MAPS_API_KEY=your_key_here

# NOAA Climate Data Online (CDO) API key
# Used for Climate chapter: monthly 30-year normals (temperature, precipitation, snowfall)
# Free registration: https://www.ncdc.noaa.gov/cdo-web/token (emailed in minutes)
# Rate limit: 5 requests/second, 10,000 requests/day
# If absent: Climate chapter renders without 30-year normals (graceful degradation)
NOAA_CDO_API_KEY=your_key_here
