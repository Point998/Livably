# Google Maps SERVER key — required for all address lookups.
# Server-side only; restrict by IP address and limit to: Geocoding API, Places API, Distance Matrix API.
GOOGLE_MAPS_API_KEY=your_key_here

# Google Maps BROWSER key — reserved for a future client-side Maps JavaScript embed.
# Must be a SEPARATE key from the server key: restrict by HTTP referrer (Websites) and limit to Maps JavaScript API only.
# Browser keys ship in page source by design; referrer restriction — not secrecy — is what protects them.
# No code consumes this yet (the current report renders no map); set it up now so it's ready when a map returns.
GOOGLE_MAPS_BROWSER_KEY=your_key_here

# NOAA Climate Data Online (CDO) API key
# Used for Climate chapter: monthly 30-year normals (temperature, precipitation, snowfall)
# Free registration: https://www.ncdc.noaa.gov/cdo-web/token (emailed in minutes)
# Rate limit: 5 requests/second, 10,000 requests/day
# If absent: Climate chapter renders without 30-year normals (graceful degradation)
NOAA_CDO_API_KEY=your_key_here

# EIA (api.eia.gov) — live US gas price for the Life-at-Address calculator (FR-033).
# Free key: https://www.eia.gov/opendata/register.php
# Optional: if unset, the calculator uses a dated fallback gas price (graceful).
EIA_API_KEY=your_key_here
